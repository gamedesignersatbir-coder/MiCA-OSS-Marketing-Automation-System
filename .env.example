# MiCA — environment variables
# Copy this file to `.env` and fill in your own values.
#
# Two paths to provide AI keys:
#   1. Fill them in here (install-time, edits this file).
#   2. Leave the AI keys blank and paste them into the in-app Settings page
#      (per-browser, stored in localStorage). Either path works.
#
# Supabase keys MUST be set here — they are infrastructure, not per-session.
# All AI keys can come from either here or Settings.

# ── Supabase (required) ──────────────────────────────────────────────────
# Create a free project at https://supabase.com → Settings → API.
# Anon keys are safe to ship to a browser — they are designed to be public.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── AI providers (required for real campaigns; not needed for demo mode) ──
# Get these at:
#   OpenRouter:  https://openrouter.ai/keys
#   Replicate:   https://replicate.com/account/api-tokens
#   HeyGen:      https://app.heygen.com/settings?nav=API
VITE_OPENROUTER_API_KEY=
VITE_REPLICATE_API_TOKEN=
VITE_HEYGEN_API_KEY=

# Optional: pin a specific OpenRouter model. If unset, defaults to
# "anthropic/claude-opus-4.6" — change to any OpenRouter model id.
# Browse available models: https://openrouter.ai/models
VITE_OPENROUTER_MODEL=

# ── Optional / advanced ──────────────────────────────────────────────────

# Hide the bottom-left "Demo Mode" toggle in production builds.
# Leave unset for self-hosters who want to let users flip demo mode on/off.
VITE_HIDE_DEMO_CONTROLS=

# Lock the deployment into demo-only mode (force demo on, hide the toggle, and
# preserve the flag across logouts). Use for public marketing/demo deployments
# where you want strangers to try MiCA without being able to use your real
# Supabase project. Self-hosters running for real should leave this unset.
VITE_FORCE_DEMO_MODE=

# Optional n8n webhooks for campaign-launch and test-email automation.
# Leave blank if you are not running an n8n instance — the launch flow will
# show a placeholder error rather than try to fire to an undefined URL.
VITE_N8N_CAMPAIGN_LAUNCH_WEBHOOK=
VITE_N8N_SEND_TEST_EMAIL_WEBHOOK=
